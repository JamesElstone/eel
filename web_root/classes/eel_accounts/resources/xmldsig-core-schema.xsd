<?xml version="1.0" encoding="UTF-8"?>
<!--
  Local, no-network declaration for the optional dsig:Signature branch imported
  by HMRC's GovTalk envelope schema. EEL Accounts uses clear/MD5 GovTalk
  authentication and never emits this optional branch; lax content preserves
  fail-closed envelope validation without a production-time remote schema load.
-->
<xsd:schema xmlns:xsd="http://www.w3.org/2001/XMLSchema"
            targetNamespace="http://www.w3.org/2000/09/xmldsig#"
            xmlns:ds="http://www.w3.org/2000/09/xmldsig#"
            elementFormDefault="qualified">
  <xsd:element name="Signature">
    <xsd:complexType>
      <xsd:sequence>
        <xsd:any namespace="##any" processContents="lax" minOccurs="0" maxOccurs="unbounded"/>
      </xsd:sequence>
      <xsd:anyAttribute namespace="##any" processContents="lax"/>
    </xsd:complexType>
  </xsd:element>
</xsd:schema>
